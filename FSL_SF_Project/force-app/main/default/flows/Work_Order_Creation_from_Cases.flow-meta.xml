    <decisions>
        <name>Check_if_needs_a_loaner_or_not</name>
        <label>Check if needs a loaner or not?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Does not need loaner</defaultConnectorLabel>
        <rules>
            <name>Needs_loaner</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Reported_Symptom__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Major Mechanical Failure (Undriveable)</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Reported_Symptom__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>EV Battery Depleted (Stranded)</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Reported_Symptom__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Accident / Collision</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Reported_Symptom__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Cracked / Broken Windshield</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Reported_Symptom__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Screen Frozen / Software Glitch</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Reported_Symptom__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Vehicle Won&apos;t Start (Dead Battery)</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Loaner_Work_type</targetReference>
            </connector>
            <label>Needs loaner</label>
        </rules>
    </decisions>
