    </decisions>
    <description>This flow will create Work orders and work order line items from cases</description>
    <environments>Default</environments>
    <formulas>
        <name>StoreWorkTypeName</name>
        <dataType>String</dataType>
        <expression>IF(CONTAINS({!varSymptomsAsText}, &apos;Tire Blowout / Flat Tire&apos;), &apos;Emergency Highway Rescue&apos;,
  IF(CONTAINS({!varSymptomsAsText}, &apos;Major Mechanical Failure&apos;), &apos;Flatbed Towing Service&apos;,
    IF(CONTAINS({!varSymptomsAsText}, &apos;EV Battery Depleted&apos;), &apos;EV Mobile Charging&apos;,
      IF(CONTAINS({!varSymptomsAsText}, &apos;Accident / Collision&apos;), &apos;Post-Accident Assessment&apos;,
        IF(CONTAINS({!varSymptomsAsText}, &apos;Check Engine / Warning Light&apos;), &apos;Standard Mobile Diagnostic&apos;,
          IF(CONTAINS({!varSymptomsAsText}, &apos;Vehicle Won\&apos;t Start&apos;), &apos;Routine Battery Swap&apos;,
            IF(CONTAINS({!varSymptomsAsText}, &apos;Cracked / Broken Windshield&apos;), &apos;Windshield Replacement (Mobile)&apos;,
              IF(CONTAINS({!varSymptomsAsText}, &apos;Keys Lost / Fob Unresponsive&apos;), &apos;Key Fob Reprogramming&apos;,
                IF(CONTAINS({!varSymptomsAsText}, &apos;Screen Frozen / Software Glitch&apos;), &apos;On-Site Software Update&apos;,
                  IF(CONTAINS({!varSymptomsAsText}, &apos;Request Temporary Replacement&apos;), &apos;White-Glove Loaner Delivery&apos;,
                    &apos;Comprehensive Vehicle Repair&apos;
                  )
                )
              )
            )
          )
        )
      )
    )
  )
)</expression>
    </formulas>
